# ---- Avalon – Database Configuration ----
DB_NAME=auction_db
DB_USER=root
DB_PASSWORD=your_password
DB_HOST=localhost

# ---- Server ----
PORT=5001
NODE_ENV=development

# ---- Authentication ----
JWT_SECRET=your_secret_key_here
JWT_EXPIRY=7d

# ---- Supabase (Cloud Storage + Realtime) ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here

# ---- Email (SMTP) ----
# For development, use Ethereal: https://ethereal.email/create
# For production, use Gmail App Password or SendGrid/Mailgun
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your_email@ethereal.email
SMTP_PASS=your_password
